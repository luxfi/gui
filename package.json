{
  "name": "@luxfi/gui",
  "version": "0.2.0",
  "description": "Lux-branded UI chrome (Header, Footer, Hero, primitives) on top of @hanzo/gui (Tamagui)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luxfi/gui.git"
  },
  "homepage": "https://github.com/luxfi/gui",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./header": {
      "types": "./dist/header/index.d.ts",
      "import": "./dist/header/index.js"
    },
    "./footer": {
      "types": "./dist/footer/index.d.ts",
      "import": "./dist/footer/index.js"
    },
    "./hero": {
      "types": "./dist/hero/index.d.ts",
      "import": "./dist/hero/index.js"
    },
    "./feature-grid": {
      "types": "./dist/feature-grid/index.d.ts",
      "import": "./dist/feature-grid/index.js"
    },
    "./stat-card": {
      "types": "./dist/stat-card/index.d.ts",
      "import": "./dist/stat-card/index.js"
    },
    "./cta": {
      "types": "./dist/cta/index.d.ts",
      "import": "./dist/cta/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    },
    "./nav": {
      "types": "./dist/nav/index.d.ts",
      "import": "./dist/nav/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@hanzo/gui": "^4.7.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "lux",
    "luxfi",
    "tamagui",
    "hanzo-gui",
    "ui",
    "components",
    "react"
  ]
}
